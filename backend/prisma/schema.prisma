generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CLIENT
}

enum ProductTier {
  STANDARD
  PREMIUM
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          UserRole @default(CLIENT)
  accessDisabled Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedClients  Client[] @relation("ClientOwner")
}

model Client {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  ownerUserId    String?
  owner          User?       @relation("ClientOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  product        ProductTier @default(STANDARD)
  accessDisabled Boolean     @default(false)
  config         Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([ownerUserId])
}
